# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=crisalida
POSTGRES_USER=crisalida
POSTGRES_PASSWORD=crisalida_secret

# MinIO
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=crisalida-assets
MINIO_USE_SSL=false

# JWT
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_REFRESH_EXPIRES_IN=7d

# Backend
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Frontend URLs
PWA_URL=http://localhost:3001
METAVERSE_URL=http://localhost:3002
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost

# Encryption key for API keys stored in DB
ENCRYPTION_KEY=32_char_encryption_key_here_change

# Worker
TICK_INTERVAL_MS=300000
BEHAVIOR_INTERVAL_MS=600000
